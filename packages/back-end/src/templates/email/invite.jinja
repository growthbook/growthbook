{% extends "base.jinja" %}
{% import "utils.jinja" as utils %}

{% block preview %}
  You've been invited to join {{ organizationName|noHyperlink }} on GrowthBook
{% endblock %}

{% block title %}
  Join {{ organizationName|noHyperlink }} on GrowthBook
{% endblock %}

{% block top %}
  {% if invitedBy %}
    <p style='margin: 0 0 24px; font-size: 15px; color: #444444; line-height: 24px;'>{{ invitedBy }} is inviting you to use GrowthBook on the <strong>{{ organizationName|noHyperlink }}</strong> account.</p>
  {% else %}
    <p style='margin: 0 0 24px; font-size: 15px; color: #444444; line-height: 24px;'>You've been invited to use GrowthBook on the <strong>{{ organizationName|noHyperlink }}</strong> account.</p>
  {% endif %}
  {{ utils.button("Accept Invitation", inviteUrl) }}
{% endblock %}

{% block bottom %}
  <p style='margin: 0 0 12px; font-size: 15px; color: #444444; line-height: 24px;'>GrowthBook is a platform for feature flagging, A/B testing, and product analytics. If you weren't expecting this invitation, you can safely ignore this email.</p>
  <p style='margin: 0; font-size: 12px;'>If the above button does not work, <a href="{{ inviteUrl }}" style="color: #888888;">click here</a> or copy this link into your browser: {{ inviteUrl }}</p>
{% endblock %}

{% block lower %}
  <p style='margin: 0;'>By continuing, you agree to join the organization managed by your Admin{% if invitedBy %} ({{ invitedBy }}){% endif %}, and acknowledge the <a href="https://www.growthbook.io/privacy" style="color: #888888; text-decoration: underline;">GrowthBook Privacy Policy</a>. <a href="https://www.growthbook.io" style="color: #888888; text-decoration: underline;">Learn more about GrowthBook</a>.</p>
{% endblock %}
