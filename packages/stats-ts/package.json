{
  "name": "stats-ts",
  "version": "0.0.1",
  "private": true,
  "main": "dist/index.js",
  "types": "src/index.ts",
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "build:clean": "rimraf dist tsconfig.tsbuildinfo",
    "build:typescript": "tsc",
    "dev": "swc src -w --out-dir dist",
    "build": "pnpm build:clean && pnpm build:typescript",
    "test": "jest",
    "clean": "rimraf node_modules",
    "type-check": "tsgo --pretty --noEmit"
  },
  "dependencies": {
    "@stdlib/stats": "^0.1.1",
    "shared": "workspace:*"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260309.1",
    "@swc-node/register": "^1.9.0",
    "@swc/cli": "^0.1.57",
    "@swc/core": "^1.3.4",
    "@swc/jest": "^0.2.23",
    "@types/jest": "^27.0.1",
    "@types/node": "^22.8.6",
    "chokidar": "^3.5.3",
    "jest": "^27.1.1",
    "prettier": "3.6.2",
    "rimraf": "^3.0.2",
    "typescript": "5.7.3"
  },
  "license": "Mixed"
}
